# Market Analysis System - Environment Configuration
# Copy this file to .env and fill in your values

# === SMTP Configuration (required for email testing) ===
MA_SMTP_HOST=smtp.gmail.com
MA_SMTP_PORT=587
MA_SMTP_USERNAME=your.email@gmail.com
MA_SMTP_PASSWORD=your_app_password_here
MA_SMTP_SENDER_EMAIL=your.email@gmail.com
MA_SMTP_USE_TLS=true

# === Database ===
MA_DB_PATH=data/market_analysis.db

# === Fund Configuration ===
MA_FUND_CNPJ=43.121.002/0001-41

# === Collection Schedule ===
MA_COLLECTION_HOUR=9
MA_COLLECTION_MINUTE=0

# === Retry Policy ===
MA_RETRY_MAX_ATTEMPTS=3
MA_RETRY_BASE_DELAY=2.0
MA_RETRY_MAX_DELAY=60.0

# === Logging ===
MA_LOG_LEVEL=INFO